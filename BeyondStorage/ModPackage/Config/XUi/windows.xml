<?xml version="1.0" encoding="UTF-8"?>
<windows>

  <!-- Player Inventory -->
  <setattribute xpath="/windows/window[@name='windowBackpack']/panel[@name='header']/rect[@controller='ContainerStandardControls']" name="pos">175,0 </setattribute>

  <append xpath="/windows/window[@name='windowBackpack']/panel[@name='header']/rect[@controller='ContainerStandardControls']">

    <rect name="beyondsmart_bp_player_backpack_only" visible="{bs_is_player_backpack_only}">
      <button depth="3" name="btnBeyondSmartPlayerInventoryPullLoadout" sprite="ui_symbol_beyond_smart_loot_pull_loadout" tooltip_key="btnBeyondSmartPlayerInventoryPullLoadout_ToolTip" pos="200, -22" style="icon32px, press, hover" pivot="center" sound="[paging_click]" />
      <button depth="3" name="btnBeyondSmartPlayerInventoryPush" sprite="ui_symbol_beyond_smart_loot_push" tooltip_key="btnBeyondSmartPlayerInventoryPush_ToolTip" pos="240, -22" style="icon32px, press, hover" pivot="center" sound="[paging_click]" />
    </rect>

    <rect name="beyondsmart_bp_player_looting" visible="{lootingorvehiclestorage}">
      <button depth="3" name="btnBeyondSmartPlayerLootingPullLoadout" sprite="ui_symbol_beyond_smart_loot_pull_loadout" tooltip_key="btnBeyondSmartPlayerInventoryPullLoadout_ToolTip" pos="200, -22" style="icon32px, press, hover" pivot="center" sound="[paging_click]" />
      <button depth="3" name="btnBeyondSmartPlayerLootingPush" sprite="ui_symbol_beyond_smart_loot_push" tooltip_key="btnBeyondSmartPlayerInventoryPush_ToolTip" pos="240, -22" style="icon32px, press, hover" pivot="center" sound="[paging_click]" />
    </rect>

  </append>

  <!-- Loot Containers + Drones -->
  <append xpath="/windows/window[@name='windowLooting']/panel[@name='header']/rect">
    <rect name="beyondsmart_bp_loot" visible="{bs_is_player_storage_open}">
      <button depth="3" name="btnBeyondSmartDronePullLoadout" visible="{bs_is_drone_window_open}" sprite="ui_symbol_beyond_smart_loot_pull_loadout" tooltip_key="btnBeyondSmartDronePullLoadout_ToolTip" pos="65, -22" style="icon32px, press, hover" pivot="center" sound="[paging_click]" />
      <button depth="3" name="btnBeyondSmartStoragePush" sprite="ui_symbol_beyond_smart_loot_push" tooltip_key="btnBeyondSmartLootWindowPush_ToolTip" pos="110, -22" style="icon32px, press, hover" pivot="center" sound="[paging_click]" />
    </rect>
  </append>

  <!-- Dew Collectors / Apiaries -->
  <append xpath="/windows/window[@name='windowDewCollector']/panel[@name='header']/rect">
    <rect name="beyondsmart_bp_collector" visible="true">
      <button depth="3" name="btnBeyondSmartCollectorPush" sprite="ui_symbol_beyond_smart_loot_push" tooltip_key="btnBeyondSmartCollectorPush_ToolTip" pos="280, -22" style="icon32px, press, hover" pivot="center" sound="[paging_click]" />
    </rect>
  </append>

  <!-- Vehicles -->
  <append xpath="/windows/window[@name='windowVehicleStorage']/panel[@name='header']/rect">
    <rect name="beyondsmart_bp_vehicle" visible="true">
      <button depth="3" name="btnBeyondSmartVehiclePullLoadout" sprite="ui_symbol_beyond_smart_loot_pull_loadout" tooltip_key="btnBeyondSmartVehiclePullLoadout_ToolTip" pos="75, -22" style="icon32px, press, hover" pivot="center" sound="[paging_click]" />
      <button depth="3" name="btnBeyondSmartVehiclePush" sprite="ui_symbol_beyond_smart_loot_push" tooltip_key="btnBeyondSmartVehiclePush_ToolTip" pos="115, -22" style="icon32px, press, hover" pivot="center" sound="[paging_click]" />
    </rect>
  </append>

  <!-- Workstation Output -->
  <append xpath="/windows/window[@name='windowOutput']/panel[@style='header.panel']/rect">
    <rect name="beyondsmart_bp_workstation_output" visible="true">
      <button depth="3" name="btnBeyondSmartWorkstationOutputPush" sprite="ui_symbol_beyond_smart_loot_push" tooltip_key="btnBeyondSmartWorkstationOutputPush_ToolTip" pos="168, -22" style="icon32px, press, hover" pivot="center" sound="[paging_click]" />
    </rect>
  </append>

</windows>