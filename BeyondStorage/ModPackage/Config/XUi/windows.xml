<?xml version="1.0" encoding="UTF-8"?>
<windows>

  <!-- Player Inventory -->
  <set xpath="/windows/window[@name='windowBackpack']/panel[@name='header']/rect[@controller='ContainerStandardControls']/@pos">200,0</set>

  <append xpath="/windows/window[@name='windowBackpack']/panel[@name='header']/rect">
    <rect name="beyondsmart_bp" visible="true" pos="150,0">
      <button depth="3" name="btnBeyondSmartPlayerInventoryPush" sprite="ui_symbol_beyond_smart_loot_push" tooltip_key="btnBeyondSmartPlayerInventoryPush_ToolTip" pos="55, -22" style="icon32px, press, hover" pivot="center" sound="[paging_click]" />
    </rect>
  </append>

  <!-- Containers -->
  <append xpath="/windows/window[@name='windowLooting']/panel[@name='header']/rect">
    <rect name="beyondsmart_bp" visible="true">
      <button depth="3" name="btnBeyondSmartLootWindowPush" sprite="ui_symbol_beyond_smart_loot_push" tooltip_key="btnBeyondSmartLootWindowPush_ToolTip" pos="110, -22" style="icon32px, press, hover" pivot="center" sound="[paging_click]" />
    </rect>
  </append>

  <!-- Dew Collectors / Apiaries -->
  <append xpath="/windows/window[@name='windowDewCollector']/panel[@name='header']/rect">
    <rect name="beyondsmart_bp" visible="true">
      <button depth="3" name="btnBeyondSmartCollectorPush" sprite="ui_symbol_beyond_smart_loot_push" tooltip_key="btnBeyondSmartCollectorPush_ToolTip" pos="280, -22" style="icon32px, press, hover" pivot="center" sound="[paging_click]" />
    </rect>
  </append>

  <!-- Vehicles -->
  <append xpath="/windows/window[@name='windowVehicleStorage']/panel[@name='header']/rect">
