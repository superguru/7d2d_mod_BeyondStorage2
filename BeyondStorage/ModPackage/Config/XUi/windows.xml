<?xml version="1.0" encoding="UTF-8"?>
<windows>

  <!-- Player Inventory -->
  <set xpath="/windows/window[@name='windowBackpack']/panel[@name='header']/rect[@controller='ContainerStandardControls']/@pos">200,0</set>

  <append xpath="/windows/window[@name='windowBackpack']/panel[@name='header']/rect">
    <rect name="beyondsmart_bp" visible="true" pos="150,0">
      <button depth="3" name="btnBeyondSmartPlayerInventoryPullLoadout" sprite="ui_symbol_beyond_smart_loot_pull_loadout" tooltip_key="btnBeyondSmartPlayerInventoryPullLoadout_ToolTip" pos="50, -22" style="icon32px, press, hover" pivot="center" sound="[paging_click]" />
      <button depth="3" name="btnBeyondSmartPlayerInventoryPush" sprite="ui_symbol_beyond_smart_loot_push" tooltip_key="btnBeyondSmartPlayerInventoryPush_ToolTip" pos="95, -22" style="icon32px, press, hover" pivot="center" sound="[paging_click]" />
    </rect>
  </append>

  <!-- Loot Containers, which includes Drones for some reason -->
  <append xpath="/windows/window[@name='windowLooting']/panel[@name='header']/rect">
    <rect name="beyondsmart_bp" visible="{bs_is_player_storage_open}">
      <button depth="3" name="btnBeyondSmartDronePullLoadout" visible="{bs_is_drone_window_open}" sprite="ui_symbol_beyond_smart_loot_pull_loadout" tooltip_key="btnBeyondSmartDronePullLoadout_ToolTip" pos="85, -22" style="icon32px, press, hover" pivot="center" sound="[paging_click]" />
      <button depth="3" name="btnBeyondSmartLootWindowPush" sprite="ui_symbol_beyond_smart_loot_push" tooltip_key="btnBeyondSmartLootWindowPush_ToolTip" pos="120, -22" style="icon32px, press, hover" pivot="center" sound="[paging_click]" />
    </rect>
  </append>
  
  <!-- Dew Collectors / Apiaries -->
  <append xpath="/windows/window[@name='windowDewCollector']/panel[@name='header']/rect">
    <rect name="beyondsmart_bp" visible="true">
      <button depth="3" name="btnBeyondSmartCollectorPush" sprite="ui_symbol_beyond_smart_loot_push" tooltip_key="btnBeyondSmartCollectorPush_ToolTip" pos="280, -22" style="icon32px, press, hover" pivot="center" sound="[paging_click]" />
    </rect>
  </append>

  <!-- Vehicles -->
  <append xpath="/windows/window[@name='windowVehicleStorage']/panel[@name='header']/rect">
    <rect name="beyondsmart_bp" visible="true">
      <button depth="3" name="btnBeyondSmartVehiclePullLoadout" sprite="ui_symbol_beyond_smart_loot_pull_loadout" tooltip_key="btnBeyondSmartVehiclePullLoadout_ToolTip" pos="40, -22" style="icon32px, press, hover" pivot="center" sound="[paging_click]" />
      <button depth="3" name="btnBeyondSmartVehiclePush" sprite="ui_symbol_beyond_smart_loot_push" tooltip_key="btnBeyondSmartVehiclePush_ToolTip" pos="90, -22" style="icon32px, press, hover" pivot="center" sound="[paging_click]" />
    </rect>
  </append>

  <!-- Workstation Output -->
  <append xpath="/windows/window[@name='windowOutput']/panel[@style='header.panel']/rect">
    <rect name="beyondsmart_bp" visible="true">
      <button depth="3" name="btnBeyondSmartWorkstationOutputPush" sprite="ui_symbol_beyond_smart_loot_push" tooltip_key="btnBeyondSmartWorkstationOutputPush_ToolTip" pos="168, -22" style="icon32px, press, hover" pivot="center" sound="[paging_click]" />
    </rect>
  </append>

</windows>